# Copy to `.env` and populate. All vars are consumed via `src/config.py`
# (pydantic Settings). Only OPENROUTER_API_KEY + GITHUB_TOKEN + REPO_NAME
# are required in practice; the rest have sensible defaults.

# --- LLM providers -------------------------------------------------------
OPENROUTER_API_KEY=${{ secrets.OPENROUTER_API_KEY }}
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/elephant-alpha
OPENROUTER_TOOL_MODEL=openrouter/openai/gpt-4o
GEMINI_API_KEY=${{ secrets.GEMINI_API_KEY }}
GROQ_API_KEY=${{ secrets.GROQ_API_KEY }}

# --- GitHub target -------------------------------------------------------
# Required for the autonomous SDLC engine to file issues, open PRs, etc.
GITHUB_TOKEN=${{ secrets.GITHUB_TOKEN }}
REPO_NAME=asshat1981ar/project-chimera
# Safety rail: keep false in production; set true only for offline dev
# when PyGithub is unavailable.
GITHUB_MOCK_ALLOWED=false

# --- Runtime mode --------------------------------------------------------
LOG_LEVEL=INFO
JSON_LOGS=true
AUTONOMOUS_MODE=false
TEST_MODE=false

# --- Optional integrations (feature flags) -------------------------------
LANGGRAPH_ENABLED=false
LLAMAINDEX_ENABLED=false
PYDANTIC_AI_ENABLED=false
INSTRUCTOR_ENABLED=false

# --- Phase-gate + self-prompt loop ---------------------------------------
PROJECT_ID=chimera
SELF_PROMPT_ENABLED=false
SELF_PROMPT_MAX_PER_HOUR=6
SELF_PROMPT_TICK_INTERVAL_SEC=60.0
SWARM_LOOP_POLL_SEC=2.0

# --- Vector retrieval (Phase 3) ------------------------------------------
# Flip RETRIEVAL_BACKEND to `vector` to enable sqlite-vec retrieval. The
# `memory` extra must be installed (pip install -e ".[memory]").
RETRIEVAL_BACKEND=keyword
EMBED_MODEL=openrouter/openai/text-embedding-3-small
EMBED_DAILY_TOKEN_CAP=200000

# --- Quality-gate tunables -----------------------------------------------
GATE_SUBPROCESS_TIMEOUT_SEC=120.0
GITHUB_DEDUP_ISSUE_SCAN_LIMIT=100

# --- Planner safety -------------------------------------------------------
# Maximum bytes the write_file fallback walker may scan per block.
# Blocks whose content field exceeds this limit are skipped to prevent
# slow O(n) scans on pathologically large LLM outputs.
PLANNER_MAX_CONTENT_BYTES=500000

# --- External SDLC MCP server --------------------------------------------
# Dormant until explicitly flipped; when true the Governor agent forwards
# phase-gate verdicts + ADRs to the `chimera_*` / `sdlc_*` MCP server.
SDLC_MCP_ENABLED=false

# --- LLM client tuning ---------------------------------------------------
LLM_TIMEOUT=30
LLM_RETRIES=3
TOKEN_QUOTA_PER_TASK=50000

# --- FinOps --------------------------------------------------------------
BUDGET_USD=10.0
